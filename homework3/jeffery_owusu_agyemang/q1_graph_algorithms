# BFS and DFS search target
# O(V + E) time, O(V) space

def bfs(target, graph, start_node):
    if start_node not in graph: return False
    queue = deque([start_node])
    visited = {start_node}
    
    while queue:
        current = queue.popleft()
        if current == target: return True
        for neighbor in graph[current]:
            if neighbor not in visited:
                visited.add(neighbor)
                queue.append(neighbor)
    return False

def dfs(target, graph, start_node):
    visited = set()
    
    def search(node):
        if node == target: return True
        visited.add(node)
        for neighbor in graph.get(node, []):
            if neighbor not in visited:
                if search(neighbor): return True
        return False
    
    return search(start_node)



# Top sort( Kahn's algorithm)
# O(V + E) time, O(V + E) space

def topological_sort_kahns(graph):
    in_degree = {u: 0 for u in graph}
    for u in graph:
        for v in graph[u]:
            in_degree[v] += 1
            
    queue = deque([u for u in in_degree if in_degree[u] == 0])
    result = []
    
    while queue:
        u = queue.popleft()
        result.append(u)
        for v in graph[u]:
            in_degree[v] -= 1
            if in_degree[v] == 0:
                queue.append(v)
                
    if len(result) != len(graph):
        print('Cycle detected, top sort is not possible.')
    return result



# Top sort (DFS)
# O(V + E) time, O(V + E) space

def topological_sort_dfs(graph):
    visited = set()
    rec_stack = set() # To detect cycles
    result = []

    def visit(u):
        if u in rec_stack:
            raise ValueError("Cycle detected!")
        if u not in visited:
            rec_stack.add(u)
            visited.add(u)
            for v in graph.get(u, []):
                visit(v)
            rec_stack.remove(u)
            result.append(u)

    for node in graph:
        if node not in visited:
            visit(node)
            
    return result[::-1]