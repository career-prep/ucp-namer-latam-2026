def run_tests():
    pq = PriorityQueue()
    
    # Test 1: Basic Insertion and Top
    pq.insert("Clean Room", 10)
    pq.insert("Fix Server", 100)
    pq.insert("Cook Dinner", 50)
    print(f"Test 1 - Expected 'Fix Server': {pq.top()}")
    
    # Test 2: Removal logic
    pq.remove()
    print(f"Test 2 - Expected 'Cook Dinner' after removal: {pq.top()}")
    
    # Test 3: Late high-priority insertion
    pq.insert("Fire Alarm", 500)
    print(f"Test 3 - Expected 'Fire Alarm': {pq.top()}")
    
    # Test 4: Empty Queue
    pq.remove() # Removes Fire Alarm
    pq.remove() # Removes Cook Dinner
    pq.remove() # Removes Clean Room
    print(f"Test 4 - Expected None for empty PQ: {pq.top()}")

run_tests()