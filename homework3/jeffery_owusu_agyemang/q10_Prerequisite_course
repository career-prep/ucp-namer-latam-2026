# Time taken: 34 minutes
# Time complexity: O(V + E)
# Space complexity: O(V + E)


from collections import deque, defaultdict

def find_course_order(courses, prereq_map):
    # 1. Setup adjacency list and in-degree count
    adj = defaultdict(list)
    in_degree = {course: 0 for course in courses}
    
    for course, prereqs in prereq_map.items():
        for p in prereqs:
            adj[p].append(course)
            in_degree[course] += 1
            
    queue = deque([c for c in courses if in_degree[c] == 0])
    result = []
    while queue:
        current = queue.popleft()
        result.append(current)
        for neighbor in adj[current]:
            in_degree[neighbor] -= 1
            if in_degree[neighbor] == 0:
                queue.append(neighbor)
                
    return result if len(result) == len(courses) else []




